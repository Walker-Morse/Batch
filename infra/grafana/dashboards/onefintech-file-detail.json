      "id": 47,
      "options": {
        "filterable": true,
        "footer": {
          "show": false
        },
        "noValue": "No failures \u2705"
      },
      "targets": [
        {
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "cfglj9j8ghwqob"
          },
          "format": "table",
          "rawQuery": true,
          "rawSql": "\nSELECT\n  dc.sequence_in_file                                                    AS seq,\n  dc.client_member_id                                                    AS member_id,\n  CASE\n    WHEN rt30.id IS NOT NULL AND (rt30.first_name IS NULL OR rt30.last_name IS NULL)\n      THEN 'MISSING NAME'\n    WHEN rt30.id IS NOT NULL\n      THEN rt30.last_name || ', ' || rt30.first_name\n    ELSE NULL\n  END                                                                    AS member_name,\n  COALESCE(\n    CASE WHEN dl.id IS NOT NULL\n      THEN '\u274c dead letter: ' || dl.failure_stage END,\n    CASE WHEN dc.failure_reason IS NOT NULL AND dc.failure_reason != ''\n      THEN '\u274c command failed: ' || dc.failure_reason END,\n    CASE WHEN rt30.fis_result_code IS NOT NULL AND rt30.fis_result_code NOT IN ('','00')\n      THEN '\u274c FIS RT30: ' || rt30.fis_result_code || ' ' || COALESCE(rt30.fis_result_message,'') END,\n    CASE WHEN rt60.fis_result_code IS NOT NULL AND rt60.fis_result_code NOT IN ('','00')\n      THEN '\u274c FIS RT60: ' || rt60.fis_result_code || ' ' || COALESCE(rt60.fis_result_message,'') END,\n    CASE WHEN rt30.id IS NOT NULL AND (rt30.first_name IS NULL OR rt30.last_name IS NULL)\n      THEN '\u274c missing required demographics' END,\n    CASE WHEN rt30.id IS NULL\n      THEN '\u26a0\ufe0f staged but no RT30 record' END,\n    '\u26a0\ufe0f incomplete \u2014 no failure recorded'\n  )                                                                      AS stopped_at,\n  CASE WHEN bf.arrived_at IS NOT NULL THEN '\u2705' ELSE '\u23f3' END            AS \"1_received\",\n  CASE WHEN dl.id IS NOT NULL AND dl.failure_stage IN ('validation','row_processing')\n       THEN '\u274c'\n       WHEN bf.status IN ('COMPLETE','PROCESSING','SUBMITTED','ASSEMBLED')\n       THEN '\u2705' ELSE '\u23f3' END                                           AS \"2_validated\",\n  CASE WHEN dl.id IS NOT NULL AND dl.failure_stage = 'row_processing'\n       THEN '\u274c'\n       WHEN dc.id IS NOT NULL THEN '\u2705' ELSE '\u23f3' END                    AS \"3_staged\",\n  CASE WHEN rt30.id IS NOT NULL AND rt30.submitted_at IS NOT NULL THEN '\u2705'\n       WHEN rt30.id IS NOT NULL THEN '\u23f3'\n       ELSE '\u23f3' END                                                     AS \"4_5_submitted\",\n  CASE\n    WHEN rt30.completed_at IS NOT NULL\n     AND (rt30.fis_result_code IS NULL OR rt30.fis_result_code IN ('','00')) THEN '\u2705'\n    WHEN rt30.completed_at IS NOT NULL THEN '\u274c'\n    ELSE '\u23f3' END                                                        AS \"6a_card_issued\",\n  CASE\n    WHEN rt60.completed_at IS NOT NULL\n     AND (rt60.fis_result_code IS NULL OR rt60.fis_result_code IN ('','00')) THEN '\u2705'\n    WHEN rt60.completed_at IS NOT NULL THEN '\u274c'\n    ELSE '\u23f3' END                                                        AS \"6b_benefit_loaded\",\n  dl.retry_count\nFROM domain_commands dc\nJOIN batch_files bf ON bf.id = dc.batch_file_id\nLEFT JOIN batch_records_rt30 rt30\n  ON rt30.batch_file_id = dc.batch_file_id AND rt30.client_member_id = dc.client_member_id\nLEFT JOIN batch_records_rt60 rt60\n  ON rt60.batch_file_id = dc.batch_file_id AND rt60.client_member_id = dc.client_member_id\nLEFT JOIN dead_letter_store dl\n  ON dl.correlation_id = bf.correlation_id AND dl.client_member_id = dc.client_member_id\nWHERE (\n  dl.id IS NOT NULL\n  OR (dc.failure_reason IS NOT NULL AND dc.failure_reason != '')\n  OR (rt30.fis_result_code IS NOT NULL AND rt30.fis_result_code NOT IN ('','00'))\n  OR (rt60.fis_result_code IS NOT NULL AND rt60.fis_result_code NOT IN ('','00'))\n  OR (rt30.id IS NOT NULL AND (rt30.first_name IS NULL OR rt30.last_name IS NULL))\n  OR rt30.id IS NULL\n)\n  AND dc.batch_file_id = '${fileId}'::uuid\nORDER BY dc.sequence_in_file ASC\nLIMIT 500\n",
          "refId": "A"
        }
      ],
      "title": "Failure path \u2014 where each record stopped",
      "type": "table"
    },
