      "targets": [
        {
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "cfglj9j8ghwqob"
          },
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT\n    m.client_member_id          AS \"Member ID\",\n    a.purse_name                AS \"Purse\",\n    a.authorization_amount      AS \"Auth Amount\",\n    CASE WHEN a.response_code = 0 THEN 'Approved' ELSE 'Declined' END AS \"Result\",\n    a.response_code             AS \"Response Code\",\n    a.response_description      AS \"Response\",\n    a.merchant_name             AS \"Merchant\",\n    a.mcc                       AS \"MCC\",\n    a.is_reversed               AS \"Reversed\",\n    a.txn_datetime_utc::date    AS \"Date\"\nFROM reporting.fact_authorization a\nLEFT JOIN reporting.dim_member m ON m.member_sk = (\n    SELECT member_sk FROM reporting.dim_member\n    WHERE client_member_id = a.pan_masked AND tenant_id = a.tenant_id LIMIT 1\n)\nWHERE a.tenant_id = 'rfu-oregon'\nORDER BY a.txn_datetime_utc DESC\nLIMIT 500",
          "refId": "A"
        }
      ],
      "title": "Authorization Detail",
      "type": "table"
    }
