          },
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT\n    txn_datetime_utc::date AS \"Date\",\n    purse_name AS \"Purse\",\n    CASE WHEN response_code=0 THEN 'Approved' ELSE 'Declined' END AS \"Result\",\n    response_code AS \"Code\",\n    ROUND(authorization_amount::numeric,2) AS \"Amount ($)\",\n    merchant_name AS \"Merchant\",\n    mcc AS \"MCC\",\n    is_reversed AS \"Reversed\",\n    pan_proxy_number AS \"Member Proxy\"\nFROM reporting.fact_authorization WHERE tenant_id='rfu-oregon'\nORDER BY txn_datetime_utc DESC LIMIT 500",
          "refId": "A"
        }
      ],
      "title": "Authorization Detail",
