          },
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT response_code AS \"Code\", response_description AS \"Description\",\n    COUNT(*) AS \"Count\",\n    ROUND(100.0*COUNT(*)/NULLIF(SUM(COUNT(*)) OVER(),0),1) AS \"% of Declines\"\nFROM reporting.fact_authorization WHERE tenant_id='rfu-oregon' AND response_code!=0\nGROUP BY response_code, response_description ORDER BY 3 DESC",
          "refId": "A"
        }
      ],
