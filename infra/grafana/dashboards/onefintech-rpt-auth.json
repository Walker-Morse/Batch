      "targets": [
        {
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "cfglj9j8ghwqob"
          },
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT purse_name AS \"Purse\",\n    COUNT(*) AS \"Total\",\n    COUNT(CASE WHEN response_code=0 THEN 1 END) AS \"Approved\",\n    COUNT(CASE WHEN response_code!=0 THEN 1 END) AS \"Declined\",\n    ROUND((100.0*COUNT(CASE WHEN response_code=0 THEN 1 END)/NULLIF(COUNT(*),0))::numeric,1) || '%' AS \"Approval %\",\n    '$' || TO_CHAR(ROUND((SUM(CASE WHEN response_code=0 THEN authorization_amount ELSE 0 END))::numeric,2),'FM999,999,990.00') AS \"Approved ($)\"\nFROM reporting.fact_authorization WHERE tenant_id='rfu-oregon'\nGROUP BY purse_name ORDER BY purse_name",
          "refId": "A"
        }
      ]
    },
