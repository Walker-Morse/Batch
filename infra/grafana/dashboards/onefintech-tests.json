        {
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "cfglj9j8ghwqob"
          },
          "format": "table",
          "rawSql": "SELECT\n  tr.run_id,\n  LEFT(tr.commit_sha, 8)   AS commit,\n  tr.branch,\n  tr.suite,\n  tr.status,\n  tr.total,\n  tr.passed,\n  tr.failed,\n  tr.skipped,\n  ROUND(100.0 * tr.passed / NULLIF(tr.total, 0), 1) AS pass_pct,\n  tr.duration_s,\n  tr.run_at\nFROM test_runs tr\nORDER BY tr.run_at DESC\nLIMIT 50",
          "refId": "A"
        }
      ],
      "title": "Test Runs",
      "type": "table"
