          "format": "table",
          "rawSql": "SELECT\n  split_part(stp.package, '/', -1) AS pkg,\n  stp.test_name,\n  stp.status,\n  stp.elapsed_s\nFROM test_steps stp\nJOIN test_runs tr ON tr.id = stp.test_run_id\nWHERE tr.run_at = (SELECT MAX(run_at) FROM test_runs)\nORDER BY stp.elapsed_s DESC NULLS LAST\nLIMIT 20",
