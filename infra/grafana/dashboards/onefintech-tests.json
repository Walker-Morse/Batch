        {
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "cfglj9j8ghwqob"
          },
          "format": "table",
          "rawSql": "SELECT\n  split_part(ts.package, '/', -1)              AS pkg,\n  ts.test_name,\n  COUNT(*) FILTER (WHERE stp.status='pass')    AS pass_count,\n  COUNT(*) FILTER (WHERE stp.status='fail')    AS fail_count,\n  MAX(tr.run_at)                               AS last_seen\nFROM test_sets ts\nJOIN test_steps stp ON stp.test_set_id = ts.id\nJOIN test_runs  tr  ON tr.id = stp.test_run_id\nGROUP BY ts.id, ts.package, ts.test_name\nHAVING COUNT(*) FILTER (WHERE stp.status='pass') > 0\n   AND COUNT(*) FILTER (WHERE stp.status='fail') > 0\nORDER BY fail_count DESC\nLIMIT 20",
          "refId": "A"
        }
      ],
      "title": "Flaky Tests (across all runs)",
      "type": "table"
