        {
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "cfglj9j8ghwqob"
          },
          "format": "table",
          "rawSql": "SELECT\n  split_part(ts.package, '/', -1)  AS pkg,\n  ts.test_name,\n  ts.suite,\n  ts.active,\n  ts.first_seen_at,\n  ts.last_seen_at,\n  COUNT(stp.id)                    AS total_runs,\n  COUNT(stp.id) FILTER (WHERE stp.status = 'fail') AS failures\nFROM test_sets ts\nLEFT JOIN test_steps stp ON stp.test_set_id = ts.id\nGROUP BY ts.id\nORDER BY ts.package, ts.test_name\nLIMIT 500",
          "refId": "A"
        }
      ],
      "title": "Test Set \u2014 Canonical Inventory",
      "type": "table"
    },
    {
      "datasource": {
        "type": "grafana-postgresql-datasource",
        "uid": "cfglj9j8ghwqob"
      },
      "description": "Tests in the canonical set that have no step record for the selected run. Empty = full coverage.",
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 6
