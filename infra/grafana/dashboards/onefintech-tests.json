      },
      "targets": [
        {
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "cfglj9j8ghwqob"
          },
          "format": "table",
          "rawSql": "SELECT\n  split_part(ts.package, '/', -1) AS pkg,\n  ts.test_name,\n  ts.suite,\n  ts.last_seen_at\nFROM test_sets ts\nWHERE ts.active = TRUE\n  AND NOT EXISTS (\n    SELECT 1\n    FROM test_steps stp\n    JOIN test_runs  tr ON tr.id = stp.test_run_id\n    WHERE stp.test_set_id = ts.id\n      AND ('$run_id' = 'all' OR tr.run_id = '$run_id')\n  )\nORDER BY ts.package, ts.test_name",
          "refId": "A"
        }
      ],
      "title": "Coverage Gaps \u2014 Tests Not Executed in Selected Run",
      "type": "table"
    },
