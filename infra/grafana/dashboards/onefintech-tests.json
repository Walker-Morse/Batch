          },
          "format": "time_series",
          "rawSql": "SELECT\n  tr.run_at                                                           AS time,\n  split_part(stp.package, '/', -1)                                   AS metric,\n  ROUND(100.0 * COUNT(*) FILTER (WHERE stp.status='pass')\n        / NULLIF(COUNT(*), 0), 1)                                    AS value\nFROM test_steps stp\nJOIN test_runs tr ON tr.id = stp.test_run_id\nGROUP BY tr.run_at, stp.package\nORDER BY tr.run_at ASC",
          "refId": "A"
        }
      ],
      "title": "Pass Rate Over Time (by Package)",
