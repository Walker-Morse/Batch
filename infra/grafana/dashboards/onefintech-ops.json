          "format": "table",
          "rawSql": "SELECT ROUND(\n             AVG(EXTRACT(EPOCH FROM (updated_at - arrived_at)) / 60.0)::numeric,\n           1)\n           FROM batch_files\n           WHERE status = 'COMPLETE'\n             AND $__timeFilter(arrived_at)",
