      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 12
      },
      "id": 6,
      "targets": [
        {
          "format": "table",
          "rawSql": "SELECT\n  bf.correlation_id,\n  bf.tenant_id,\n  bf.client_id,\n  bf.file_type,\n  bf.record_count,\n  bf.malformed_count,\n  bf.status,\n  COUNT(CASE WHEN brc.status = 'enrolled' THEN 1 END) as enrolled,\n  COUNT(CASE WHEN brc.status = 'dead_lettered' THEN 1 END) as dead_lettered,\n  bf.arrived_at as received_at\nFROM batch_files bf\nLEFT JOIN batch_records_common brc ON brc.batch_file_id = bf.id\nGROUP BY bf.id\nORDER BY bf.arrived_at DESC\nLIMIT 15",
          "refId": "A"
        }
      ],
      "title": "Recent Pipeline Runs",
      "type": "table"
    }
