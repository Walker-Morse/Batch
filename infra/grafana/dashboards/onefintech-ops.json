          }
        ]
      },
      "targets": [
        {
          "format": "table",
          "rawSql": "SELECT\n  failure_stage,\n  failure_reason,\n  COUNT(*) as count,\n  MAX(created_at) as last_seen\nFROM dead_letter_store\nWHERE created_at >= NOW() - INTERVAL '24 hours'\nGROUP BY failure_stage, failure_reason\nORDER BY count DESC\nLIMIT 20",
          "refId": "A"
        }
      ],
      "title": "Dead Letters by Failure Reason",
      "transformations": [
        {
          "id": "organize",
          "options": {}
        }
      ],
      "type": "table"
