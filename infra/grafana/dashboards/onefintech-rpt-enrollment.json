            "uid": "cfglj9j8ghwqob"
          },
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT m.client_member_id AS \"Member ID\",m.first_name AS \"First Name\",m.last_name AS \"Last Name\",\n    fe.srg_file_type AS \"File Type\",fe.fis_record_type AS \"Record Type\",\n    fe.processing_status AS \"Status\",fe.correlation_id AS \"Correlation ID\",fe.created_at::date AS \"Created\"\nFROM reporting.fact_enrollments fe LEFT JOIN reporting.dim_member m ON m.member_sk=fe.dim_member_sk\nWHERE fe.tenant_id='rfu-oregon' ORDER BY fe.created_at DESC LIMIT 500",
          "refId": "A"
        }
