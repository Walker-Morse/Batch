      "pluginVersion": "10.4.3",
      "targets": [
        {
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "cfglj9j8ghwqob"
          },
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT fe.correlation_id AS \"Correlation ID\",fe.srg_file_type AS \"SRG File Type\",\n    fe.fis_record_type AS \"FIS Record Type\",COUNT(*) AS \"Total\",\n    COUNT(CASE WHEN fe.processing_status='STAGED' THEN 1 END) AS \"Staged\",\n    COUNT(CASE WHEN fe.processing_status='ACCEPTED' THEN 1 END) AS \"Accepted\",\n    COUNT(CASE WHEN fe.processing_status='FAILED' THEN 1 END) AS \"Failed\",\n    MIN(fe.created_at)::date AS \"File Date\"\nFROM reporting.fact_enrollments fe WHERE fe.tenant_id='rfu-oregon'\nGROUP BY fe.correlation_id,fe.srg_file_type,fe.fis_record_type ORDER BY MIN(fe.created_at) DESC",
          "refId": "A"
        }
      ]
    },
