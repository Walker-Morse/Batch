      "pluginVersion": "10.4.3",
      "targets": [
        {
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "cfglj9j8ghwqob"
          },
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT\n    m.client_member_id          AS \"Member ID\",\n    m.first_name                AS \"First Name\",\n    m.last_name                 AS \"Last Name\",\n    fe.srg_file_type            AS \"File Type\",\n    fe.fis_record_type          AS \"Record Type\",\n    fe.processing_status        AS \"Status\",\n    fe.correlation_id           AS \"Correlation ID\",\n    fe.date_sk::text            AS \"Date SK\",\n    fe.created_at::date         AS \"Created\"\nFROM reporting.fact_enrollments fe\nLEFT JOIN reporting.dim_member m ON m.member_sk = fe.dim_member_sk\nWHERE fe.tenant_id = 'rfu-oregon'\nORDER BY fe.created_at DESC, fe.row_sequence_number\nLIMIT 500",
          "refId": "A"
        }
      ],
      "title": "Member-Level Enrollment Detail",
      "type": "table"
    }
