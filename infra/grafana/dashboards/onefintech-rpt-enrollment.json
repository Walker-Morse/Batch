    {
      "id": 20,
      "type": "table",
      "title": "Enrollment by Batch File",
      "datasource": {
        "type": "grafana-postgresql-datasource",
        "uid": "cfglj9j8ghwqob"
      },
      "gridPos": {
        "x": 0,
        "y": 14,
