      "targets": [
        {
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "cfglj9j8ghwqob"
          },
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT\n    fe.correlation_id               AS \"Correlation ID\",\n    fe.srg_file_type                AS \"SRG File Type\",\n    fe.fis_record_type              AS \"FIS Record Type\",\n    COUNT(*)                        AS \"Total Records\",\n    COUNT(CASE WHEN fe.processing_status='STAGED'    THEN 1 END) AS \"Staged\",\n    COUNT(CASE WHEN fe.processing_status='ACCEPTED'  THEN 1 END) AS \"Accepted\",\n    COUNT(CASE WHEN fe.processing_status='FAILED'    THEN 1 END) AS \"Failed\",\n    MIN(fe.created_at)::date        AS \"File Date\"\nFROM reporting.fact_enrollments fe\nWHERE fe.tenant_id = 'rfu-oregon'\nGROUP BY fe.correlation_id, fe.srg_file_type, fe.fis_record_type\nORDER BY MIN(fe.created_at) DESC",
          "refId": "A"
        }
      ],
      "title": "Enrollment by Batch File",
      "type": "table"
    },
