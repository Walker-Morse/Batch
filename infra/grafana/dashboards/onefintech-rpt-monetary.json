      "targets": [
        {
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "cfglj9j8ghwqob"
          },
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT\n    work_of_date AS \"Work Date\",\n    purse_code AS \"Purse\",\n    txn_type_code AS \"Txn Type\",\n    response_code AS \"Response\",\n    '$' || TO_CHAR(ROUND((settle_amount)::numeric,2),'FM999,999,990.00') AS \"Settle Amount\",\n    '$' || TO_CHAR(ROUND((authorization_amount)::numeric,2),'FM999,999,990.00') AS \"Auth Amount\",\n    merchant_name AS \"Merchant\",\n    mcc AS \"MCC\",\n    pan_proxy_number AS \"Member Proxy\",\n    pan_masked AS \"PAN\",\n    txn_local_datetime AS \"Txn Time\"\nFROM reporting.fact_monetary WHERE tenant_id='rfu-oregon'\nORDER BY work_of_date DESC, txn_local_datetime DESC\nLIMIT 500",
          "refId": "A"
        }
      ]
    }
