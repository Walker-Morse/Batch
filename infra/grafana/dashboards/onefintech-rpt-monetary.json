      "id": 10,
      "type": "table",
      "title": "Transactions by Purse",
      "datasource": {
        "type": "grafana-postgresql-datasource",
        "uid": "cfglj9j8ghwqob"
      },
      "gridPos": {
        "x": 0,
        "y": 14,
