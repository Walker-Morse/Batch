      "targets": [
        {
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "cfglj9j8ghwqob"
          },
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT purse_code AS \"Purse\",\n    txn_type_code AS \"Txn Type\",\n    COUNT(*) AS \"Count\",\n    '$' || TO_CHAR(ROUND((SUM(settle_amount))::numeric,2),'FM999,999,990.00') AS \"Total\",\n    '$' || TO_CHAR(ROUND((AVG(settle_amount))::numeric,2),'FM999,999,990.00') AS \"Avg\"\nFROM reporting.fact_monetary WHERE tenant_id='rfu-oregon'\nGROUP BY purse_code, txn_type_code ORDER BY purse_code, txn_type_code",
          "refId": "A"
        }
      ]
    },
