          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT\n    purse_code AS \"Purse Code\",\n    purse_number AS \"Purse Number\",\n    purse_status AS \"Status\",\n    '$' || TO_CHAR(ROUND((min_load_amount)::numeric,2),'FM999,999,990.00') AS \"Min Load\",\n    '$' || TO_CHAR(ROUND((max_load_amount)::numeric,2),'FM999,999,990.00') AS \"Max Load\",\n    '$' || TO_CHAR(ROUND((min_balance_amount)::numeric,2),'FM999,999,990.00') AS \"Min Balance\",\n    '$' || TO_CHAR(ROUND((max_balance_amount)::numeric,2),'FM999,999,990.00') AS \"Max Balance\",\n    filter_type AS \"Filter Type\",\n    filter_network_name AS \"Filter Network\",\n    spend_categories_raw AS \"Spend Categories\",\n    purse_start_date AS \"Start Date\",\n    purse_end_date AS \"End Date\",\n    file_date AS \"Config Date\"\nFROM reporting.dim_purse_config\nORDER BY purse_code",
          "refId": "A"
        }
      ]
