          },
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT\n    s.subprogram_id         AS \"Subprogram ID\",\n    s.subprogram_name       AS \"Subprogram Name\",\n    s.program_id            AS \"Program ID\",\n    s.program_name          AS \"Program Name\",\n    s.client_id             AS \"Client ID\",\n    s.client_name           AS \"Client Name\",\n    s.is_active             AS \"Active\",\n    s.is_reloadable         AS \"Reloadable\",\n    s.initial_card_status   AS \"Initial Card Status\",\n    s.market_segment        AS \"Market Segment\",\n    s.file_date             AS \"Config Date\"\nFROM reporting.dim_subprogram s\nORDER BY s.file_date DESC",
          "refId": "A"
        }
