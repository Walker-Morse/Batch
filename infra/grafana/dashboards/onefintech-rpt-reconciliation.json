        {
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "cfglj9j8ghwqob"
          },
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT m.client_member_id AS \"Member ID\",m.first_name AS \"First Name\",m.last_name AS \"Last Name\",\n    r.fis_record_type AS \"Record Type\",r.fis_result_code AS \"Result Code\",\n    r.fis_result_message AS \"Result Message\",r.reconciliation_status AS \"Status\",\n    m.fis_person_id AS \"FIS Person ID\",r.correlation_id AS \"Correlation ID\",\n    r.reconciled_at::date AS \"Reconciled Date\"\nFROM reporting.fact_reconciliation r LEFT JOIN reporting.dim_member m ON m.member_sk=r.dim_member_sk\nWHERE r.tenant_id='rfu-oregon' ORDER BY r.reconciliation_status DESC,r.reconciled_at DESC NULLS LAST LIMIT 500",
          "refId": "A"
        }
      ]
    }
