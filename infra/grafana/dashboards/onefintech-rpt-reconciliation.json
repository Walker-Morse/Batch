      "targets": [
        {
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "cfglj9j8ghwqob"
          },
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT\n    m.client_member_id          AS \"Member ID\",\n    m.first_name                AS \"First Name\",\n    m.last_name                 AS \"Last Name\",\n    r.fis_record_type           AS \"Record Type\",\n    r.fis_result_code           AS \"Result Code\",\n    r.fis_result_message        AS \"Result Message\",\n    r.reconciliation_status     AS \"Status\",\n    m.fis_person_id             AS \"FIS Person ID\",\n    r.correlation_id            AS \"Correlation ID\",\n    r.batch_file_id             AS \"Batch File ID\",\n    r.row_sequence_number       AS \"Sequence\",\n    r.reconciled_at::date       AS \"Reconciled Date\"\nFROM reporting.fact_reconciliation r\nLEFT JOIN reporting.dim_member m ON m.member_sk = r.dim_member_sk\nWHERE r.tenant_id = 'rfu-oregon'\nORDER BY r.reconciliation_status DESC, r.reconciled_at DESC NULLS LAST\nLIMIT 500",
          "refId": "A"
        }
      ],
      "title": "Reconciliation Results \u2014 All Records",
      "type": "table"
    }
