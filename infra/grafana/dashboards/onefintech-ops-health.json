          "format": "table",
          "rawQuery": true,
          "rawSql": "\nSELECT\n  av.benefit_type                                         AS \"Benefit Type\",\n  av.version_number                                       AS \"Version\",\n  av.rule_count                                           AS \"Rules\",\n  av.uploaded_at  AT TIME ZONE 'UTC'                      AS \"Uploaded\",\n  av.fis_ack_received_at AT TIME ZONE 'UTC'               AS \"FIS Ack\",\n  CASE\n    WHEN av.fis_ack_received_at IS NOT NULL THEN 'ACK received'\n    WHEN NOW() - av.uploaded_at > INTERVAL '24 hours'    THEN 'ACK overdue'\n    ELSE 'pending'\n  END                                                     AS \"Ack Status\",\n  ROUND(EXTRACT(EPOCH FROM (COALESCE(av.fis_ack_received_at, NOW()) - av.uploaded_at))/3600.0::numeric,1) AS \"Hours to Ack\"\nFROM apl_versions av\nORDER BY av.uploaded_at DESC\nLIMIT 10\n",
          "refId": "A"
        }
      ],
      "title": "APL version ack status",
