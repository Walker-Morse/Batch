          "rawSql": "\nSELECT\n  bf.tenant_id || ' \u00b7 ' || bf.file_type || ' \u00b7 '\n    || TO_CHAR(bf.arrived_at AT TIME ZONE 'UTC', 'MM-DD HH24:MI')  AS \"File\",\n  bf.client_id                                                       AS \"Client\",\n  bf.file_type                                                       AS \"Type\",\n  bf.status                                                          AS \"Status\",\n  bf.record_count                                                    AS \"Rows\",\n  bf.malformed_count                                                 AS \"Malformed\",\n  CASE WHEN bf.submitted_at IS NOT NULL THEN\n    ROUND(EXTRACT(EPOCH FROM (bf.submitted_at - bf.arrived_at))/60.0::numeric,1)\n  END                                                                AS \"Duration (min)\",\n  bf.arrived_at AT TIME ZONE 'UTC'                                   AS \"Arrived\",\n  bf.id                                                              AS \"File ID\"\nFROM batch_files bf\nWHERE $__timeFilter(bf.arrived_at)\nORDER BY bf.arrived_at DESC\nLIMIT 50\n",
          "refId": "A"
        }
      ],
      "title": "Recent pipeline runs",
      "type": "table"
    },
