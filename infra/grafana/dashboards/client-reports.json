      "targets": [
        {
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "cfglj9j8ghwqob"
          },
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT\n    m.client_member_id AS \"Member ID\",\n    m.fis_person_id AS \"FIS Person ID\",\n    r.fis_record_type AS \"Record Type\",\n    r.fis_result_code AS \"Result Code\",\n    r.fis_result_message AS \"Result Message\",\n    r.reconciliation_status AS \"Status\",\n    r.correlation_id AS \"Correlation ID\",\n    r.reconciled_at::date AS \"Reconciled Date\"\nFROM reporting.fact_reconciliation r\nLEFT JOIN reporting.dim_member m ON m.member_sk = r.dim_member_sk\nWHERE r.tenant_id = 'rfu-oregon'\nORDER BY r.reconciled_at DESC NULLS LAST, r.row_sequence_number\nLIMIT 500",
          "refId": "A"
        }
      ]
    }
