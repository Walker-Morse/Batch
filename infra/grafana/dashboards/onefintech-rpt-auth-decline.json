      "targets": [
        {
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "cfglj9j8ghwqob"
          },
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT\n    work_of_date AS \"Date\",\n    purse_number AS \"Purse #\",\n    COALESCE(reason_code::text, 'N/A') AS \"Reason Code\",\n    reason_code_description AS \"Description\",\n    decline_count AS \"Decline Count\",\n    '$' || TO_CHAR(ROUND((declined_amount)::numeric,2),'FM999,999,990.00') AS \"Declined Amount\"\nFROM reporting.vw_auth_decline_summary\nWHERE tenant_id='rfu-oregon'\nORDER BY work_of_date DESC, decline_count DESC",
          "refId": "A"
        }
      ]
    },
