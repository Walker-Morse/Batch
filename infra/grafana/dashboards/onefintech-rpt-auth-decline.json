      "pluginVersion": "10.4.3",
      "targets": [
        {
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "cfglj9j8ghwqob"
          },
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT\n    response_code AS \"Response Code\",\n    CASE response_code WHEN 0 THEN 'Approved' WHEN 51 THEN 'Insufficient Funds' WHEN 57 THEN 'Txn Not Permitted' WHEN 61 THEN 'Exceeds Limit' ELSE 'Other' END AS \"Description\",\n    COUNT(*) AS \"Count\",\n    '$' || TO_CHAR(ROUND((SUM(authorization_amount))::numeric,2),'FM999,999,990.00') AS \"Total Amount\",\n    ROUND(COUNT(*) * 100.0 / NULLIF(SUM(COUNT(*)) OVER (),0), 1) || '%' AS \"% of All Auths\"\nFROM reporting.fact_authorization\nWHERE tenant_id='rfu-oregon'\nGROUP BY response_code\nORDER BY count DESC",
          "refId": "A"
        }
      ]
    }
