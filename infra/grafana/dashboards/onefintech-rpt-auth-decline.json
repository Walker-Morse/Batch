      "targets": [
        {
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "cfglj9j8ghwqob"
          },
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT\n    work_of_date AS \"Date\",\n    purse_number AS \"Purse #\",\n    response_code AS \"Response Code\",\n    COUNT(*) AS \"Count\",\n    '$' || TO_CHAR(ROUND((SUM(authorization_amount))::numeric,2),'FM999,999,990.00') AS \"Total Amount\",\n    '$' || TO_CHAR(ROUND((AVG(authorization_amount))::numeric,2),'FM999,999,990.00') AS \"Avg Amount\",\n    ROUND((COUNT(*) * 100.0 / NULLIF(SUM(COUNT(*)) OVER (PARTITION BY work_of_date),0))::numeric,1) || '%' AS \"% of Day\"\nFROM reporting.fact_authorization\nWHERE tenant_id='rfu-oregon'\nGROUP BY work_of_date, purse_number, response_code\nORDER BY work_of_date DESC, count DESC",
          "refId": "A"
        }
      ]
    },
