      "id": 10,
      "type": "table",
      "title": "Daily Monetary Totals by Purse",
      "datasource": {
        "type": "grafana-postgresql-datasource",
        "uid": "cfglj9j8ghwqob"
      },
      "gridPos": {
        "x": 0,
