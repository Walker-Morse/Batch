      "targets": [
        {
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "cfglj9j8ghwqob"
          },
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT\n    purse_code AS \"Purse\",\n    SUM(txn_count) AS \"Total Txns\",\n    '$' || TO_CHAR(ROUND((SUM(total_credits))::numeric,2),'FM999,999,990.00') AS \"Total Credits\",\n    '$' || TO_CHAR(ROUND((SUM(total_debits))::numeric,2),'FM999,999,990.00') AS \"Total Debits\",\n    '$' || TO_CHAR(ROUND((SUM(net_amount))::numeric,2),'FM999,999,990.00') AS \"Net Amount\",\n    '$' || TO_CHAR(ROUND((AVG(net_amount/NULLIF(txn_count,0)))::numeric,2),'FM999,999,990.00') AS \"Avg Txn ($)\"\nFROM reporting.vw_daily_monetary_summary\nWHERE tenant_id='rfu-oregon'\nGROUP BY purse_code\nORDER BY purse_code",
          "refId": "A"
        }
      ]
    }
