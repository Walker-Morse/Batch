        {
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "cfglj9j8ghwqob"
          },
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT\n    work_of_date AS \"Date\",\n    purse_code AS \"Purse\",\n    txn_count AS \"Txn Count\",\n    '$' || TO_CHAR(ROUND((total_credits)::numeric,2),'FM999,999,990.00') AS \"Credits\",\n    '$' || TO_CHAR(ROUND((total_debits)::numeric,2),'FM999,999,990.00') AS \"Debits\",\n    '$' || TO_CHAR(ROUND((net_amount)::numeric,2),'FM999,999,990.00') AS \"Net\"\nFROM reporting.vw_daily_monetary_summary\nWHERE tenant_id='rfu-oregon'\nORDER BY work_of_date DESC, purse_code",
          "refId": "A"
        }
      ]
    },
