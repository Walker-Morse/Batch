      "targets": [
        {
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "cfglj9j8ghwqob"
          },
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT m.client_member_id AS \"Client Member ID\",m.first_name AS \"First Name\",m.last_name AS \"Last Name\",\n    m.fis_person_id AS \"FIS Person ID\",m.fis_cuid AS \"FIS CUID\",c.fis_card_id AS \"FIS Card ID\",\n    CASE c.card_status WHEN 1 THEN 'Active' WHEN 2 THEN 'Suspended' WHEN 3 THEN 'Closed' ELSE 'New' END AS \"Status\",\n    c.issued_at::date AS \"Start Date\",c.activated_at::date AS \"Activated Date\"\nFROM reporting.dim_member m LEFT JOIN reporting.dim_card c ON c.dim_member_sk=m.member_sk\nWHERE m.tenant_id='rfu-oregon' AND m.is_current=true ORDER BY m.client_member_id",
          "refId": "A"
        }
      ]
    }
