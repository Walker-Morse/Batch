    {
      "id": 20,
      "type": "table",
      "title": "Card Status \u2014 All Members",
      "datasource": {
        "type": "grafana-postgresql-datasource",
        "uid": "cfglj9j8ghwqob"
      },
      "gridPos": {
        "x": 0,
        "y": 14,
