            "uid": "cfglj9j8ghwqob"
          },
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT\n    CASE card_status_code WHEN 1 THEN 'Active' WHEN 2 THEN 'Suspended' WHEN 3 THEN 'Closed' ELSE card_status_code::text END AS \"Card Status\",\n    COUNT(*) AS \"Count\"\nFROM reporting.fact_non_monetary\nWHERE tenant_id='rfu-oregon'\nGROUP BY card_status_code ORDER BY 2 DESC",
          "refId": "A"
        }
      ]
    },
