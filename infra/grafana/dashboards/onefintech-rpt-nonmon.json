      "pluginVersion": "10.4.3",
      "targets": [
        {
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "cfglj9j8ghwqob"
          },
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT\n    event_type_code AS \"Event Type Code\",\n    event_description AS \"Description\",\n    COUNT(*) AS \"Count\",\n    COUNT(CASE WHEN card_status_code=1 THEN 1 END) AS \"Active Cards\",\n    MIN(event_datetime)::date AS \"First Seen\",\n    MAX(event_datetime)::date AS \"Last Seen\"\nFROM reporting.fact_non_monetary\nWHERE tenant_id='rfu-oregon'\nGROUP BY event_type_code, event_description\nORDER BY 3 DESC",
          "refId": "A"
        }
      ]
    },
