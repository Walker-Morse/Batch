          "format": "table",
          "rawQuery": true,
          "rawSql": "\nSELECT\n  pg.client_name       AS \"Client\",\n  pg.subprogram_name   AS \"Subprogram\",\n  pg.benefit_type      AS \"Benefit Type\",\n  pg.state             AS \"State\",\n  pg.is_active         AS \"Active\",\n  pg.program_start_date AS \"Start Date\",\n  pg.fis_pack_id       AS \"Pack ID\",\n  pg.fis_subprogram_id AS \"FIS Subprogram ID\"\nFROM programs pg\nORDER BY pg.client_name, pg.benefit_type\n",
          "refId": "A"
        }
      ],
