      "targets": [
        {
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "cfglj9j8ghwqob"
          },
          "format": "table",
          "rawQuery": true,
          "rawSql": "\nSELECT\n  av.benefit_type                                          AS \"Benefit Type\",\n  av.version_number                                        AS \"Version\",\n  av.rule_count                                            AS \"Rules\",\n  av.s3_key                                                AS \"S3 Key\",\n  av.uploaded_at AT TIME ZONE 'UTC'                        AS \"Uploaded\",\n  av.uploaded_by                                           AS \"Uploaded By\",\n  av.fis_ack_received_at AT TIME ZONE 'UTC'                AS \"FIS Ack Received\",\n  CASE\n    WHEN av.fis_ack_received_at IS NOT NULL THEN 'ACK received'\n    WHEN NOW() - av.uploaded_at > INTERVAL '24 hours'     THEN 'ACK overdue'\n    ELSE 'pending'\n  END                                                      AS \"Ack Status\",\n  av.notes                                                 AS \"Notes\"\nFROM apl_versions av\nORDER BY av.uploaded_at DESC\nLIMIT 50\n",
          "refId": "A"
        }
      ],
      "title": "APL versions",
      "type": "table"
    }
