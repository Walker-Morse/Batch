      "targets": [
        {
          "format": "table",
          "rawSql": "SELECT\n  bf.correlation_id,\n  brc.record_type,\n  brc.status,\n  COUNT(*) as count\nFROM batch_records_common brc\nJOIN batch_files bf ON bf.id = brc.batch_file_id\nWHERE $__timeFilter(bf.arrived_at)\nGROUP BY bf.correlation_id, brc.record_type, brc.status\nORDER BY bf.correlation_id, brc.record_type, brc.status",
          "refId": "A",
          "datasource": {
