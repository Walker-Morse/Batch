      "id": 4,
      "targets": [
        {
          "format": "table",
          "rawSql": "SELECT\n  bf.correlation_id,\n  brc.record_type,\n  brc.status,\n  COUNT(*) as count\nFROM batch_records_common brc\nJOIN batch_files bf ON bf.id = brc.batch_file_id\nWHERE bf.arrived_at >= NOW() - INTERVAL '24 hours'\nGROUP BY bf.correlation_id, brc.record_type, brc.status\nORDER BY bf.correlation_id, brc.record_type, brc.status",
          "refId": "A"
        }
      ],
      "title": "Rows by Record Type and Status",
      "type": "table"
    },
