      "targets": [
        {
          "format": "table",
          "rawSql": "SELECT\n  bf.correlation_id,\n  bf.tenant_id,\n  bf.client_id,\n  bf.file_type,\n  bf.record_count as submitted_rows,\n  bf.malformed_count,\n  COUNT(CASE WHEN brc.status = 'enrolled' THEN 1 END) as enrolled,\n  COUNT(CASE WHEN brc.status = 'dead_lettered' THEN 1 END) as dead_lettered,\n  ROUND(100.0 * COUNT(CASE WHEN brc.status = 'enrolled' THEN 1 END) / NULLIF(bf.record_count,0), 1) as enroll_pct,\n  bf.status as file_status,\n  bf.arrived_at as received_at\nFROM batch_files bf\nLEFT JOIN batch_records_common brc ON brc.batch_file_id = bf.id\nGROUP BY bf.id\nORDER BY bf.arrived_at DESC\nLIMIT 30",
          "refId": "A"
        }
      ],
      "title": "File Inventory",
      "type": "table"
