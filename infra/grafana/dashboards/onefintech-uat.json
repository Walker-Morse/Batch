      "targets": [
        {
          "format": "table",
          "rawSql": "SELECT\n  bf.correlation_id,\n  brc.sequence_in_file,\n  brc.record_type,\n  brc.client_member_id,\n  brc.status,\n  brc.fis_result_code,\n  brc.fis_result_message,\n  brc.staged_at,\n  brc.completed_at\nFROM batch_records_common brc\nJOIN batch_files bf ON bf.id = brc.batch_file_id\nWHERE bf.correlation_id::text LIKE CASE WHEN '$correlation_id' = '' THEN '%' ELSE '$correlation_id' END\nORDER BY bf.correlation_id, brc.sequence_in_file ASC\nLIMIT 200",
