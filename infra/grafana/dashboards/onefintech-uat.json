      "targets": [
        {
          "format": "table",
          "rawSql": "SELECT\n  c.client_member_id,\n  c.first_name,\n  c.last_name,\n  c.date_of_birth,\n  c.status as consumer_status,\n  p.purse_type,\n  p.status as purse_status,\n  p.available_balance_cents,\n  p.effective_date as benefit_start,\n  p.expiry_date as benefit_end,\n  ca.pan_masked,\n  ca.card_status,\n  c.created_at as enrolled_at\nFROM consumers c\nLEFT JOIN purses p ON p.consumer_id = c.id\nLEFT JOIN cards ca ON ca.consumer_id = c.id\nWHERE c.client_member_id LIKE CASE WHEN '$medicaid_id' = '' THEN '%' ELSE '$medicaid_id' END\nORDER BY c.created_at DESC\nLIMIT 200",
          "refId": "A",
