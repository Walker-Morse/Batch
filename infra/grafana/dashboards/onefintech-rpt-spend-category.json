    {
      "id": 12,
      "type": "table",
      "title": "Totals by Spend Category",
      "datasource": {
        "type": "grafana-postgresql-datasource",
        "uid": "cfglj9j8ghwqob"
      },
      "gridPos": {
        "x": 0,
        "y": 23,
