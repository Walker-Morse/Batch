        },
        "showHeader": true
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "filterable": true,
            "displayMode": "auto"
          }
        },
        "overrides": []
      },
      "pluginVersion": "10.4.3",
      "targets": [
        {
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "cfglj9j8ghwqob"
          },
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT\n    spend_category_code AS \"Category\",\n    SUM(transaction_count) AS \"Txns\",\n    SUM(line_item_count) AS \"Line Items\",\n    '$' || TO_CHAR(ROUND((SUM(gross_item_amount))::numeric,2),'FM999,999,990.00') AS \"Gross Amount\",\n    '$' || TO_CHAR(ROUND((SUM(funded_amount))::numeric,2),'FM999,999,990.00') AS \"Funded\",\n    '$' || TO_CHAR(ROUND((SUM(tax_amount))::numeric,2),'FM999,999,990.00') AS \"Tax\",\n    '$' || TO_CHAR(ROUND((SUM(discount_amount))::numeric,2),'FM999,999,990.00') AS \"Discount\",\n    ROUND((SUM(funded_amount)*100.0/NULLIF(SUM(gross_item_amount),0))::numeric,1) || '%' AS \"Fund Rate %\"\nFROM reporting.vw_spend_category_summary\nWHERE tenant_id='rfu-oregon'\nGROUP BY spend_category_code\nORDER BY spend_category_code",
          "refId": "A"
        }
      ]
    },
