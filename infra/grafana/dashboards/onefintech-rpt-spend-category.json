    {
      "id": 10,
      "type": "table",
      "title": "Category Summary (from view)",
      "datasource": {
        "type": "grafana-postgresql-datasource",
        "uid": "cfglj9j8ghwqob"
      },
      "gridPos": {
        "x": 0,
        "y": 12,
        "w": 24,
        "h": 10
      },
      "options": {
        "cellHeight": "sm",
        "footer": {
          "show": false
        },
        "showHeader": true
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "filterable": true,
            "displayMode": "auto"
          }
        },
        "overrides": []
      },
      "pluginVersion": "10.4.3",
      "targets": [
        {
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "cfglj9j8ghwqob"
          },
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT\n    work_of_date AS \"Date\",\n    spend_category_code AS \"Category\",\n    mcc AS \"MCC\",\n    mcc_description AS \"MCC Description\",\n    transaction_count AS \"Txns\",\n    line_item_count AS \"Line Items\",\n    '$' || TO_CHAR(ROUND((gross_item_amount)::numeric,2),'FM999,999,990.00') AS \"Gross Amount\",\n    '$' || TO_CHAR(ROUND((funded_amount)::numeric,2),'FM999,999,990.00') AS \"Funded Amount\",\n    '$' || TO_CHAR(ROUND((tax_amount)::numeric,2),'FM999,999,990.00') AS \"Tax\",\n    '$' || TO_CHAR(ROUND((discount_amount)::numeric,2),'FM999,999,990.00') AS \"Discount\"\nFROM reporting.vw_spend_category_summary\nWHERE tenant_id='rfu-oregon'\nORDER BY work_of_date DESC, spend_category_code, gross_item_amount DESC",
          "refId": "A"
        }
      ]
    },
