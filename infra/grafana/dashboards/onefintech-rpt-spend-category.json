            "uid": "cfglj9j8ghwqob"
          },
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT\n    mcc AS \"MCC\",\n    mcc_description AS \"Description\",\n    SUM(transaction_count) AS \"Txns\",\n    '$' || TO_CHAR(ROUND((SUM(gross_item_amount))::numeric,2),'FM999,999,990.00') AS \"Gross Amount\",\n    '$' || TO_CHAR(ROUND((SUM(funded_amount))::numeric,2),'FM999,999,990.00') AS \"Funded\",\n    ROUND((SUM(funded_amount)*100.0/NULLIF(SUM(gross_item_amount),0))::numeric,1) || '%' AS \"Fund Rate %\"\nFROM reporting.vw_spend_category_summary\nWHERE tenant_id='rfu-oregon'\nGROUP BY mcc, mcc_description\nORDER BY SUM(gross_item_amount) DESC",
          "refId": "A"
        }
      ]
