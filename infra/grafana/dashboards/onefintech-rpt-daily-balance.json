    {
      "id": 12,
      "type": "table",
      "title": "Load vs Spend by Purse",
      "datasource": {
        "type": "grafana-postgresql-datasource",
        "uid": "cfglj9j8ghwqob"
      },
      "gridPos": {
        "x": 0,
        "y": 23,
        "w": 24,
        "h": 8
      },
      "options": {
        "cellHeight": "sm",
        "footer": {
          "show": false
        },
        "showHeader": true
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "filterable": true,
            "displayMode": "auto"
          }
        },
        "overrides": []
      },
      "pluginVersion": "10.4.3",
      "targets": [
        {
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "cfglj9j8ghwqob"
          },
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT\n    purse_name AS \"Purse\",\n    SUM(account_count) AS \"Account-Days\",\n    '$' || TO_CHAR(ROUND((SUM(total_loads))::numeric,2),'FM999,999,990.00') AS \"Total Loaded\",\n    '$' || TO_CHAR(ROUND((SUM(total_purchases))::numeric,2),'FM999,999,990.00') AS \"Total Spent\",\n    '$' || TO_CHAR(ROUND((SUM(total_closing_balance))::numeric,2),'FM999,999,990.00') AS \"Total Remaining\",\n    ROUND((CASE WHEN SUM(total_loads)>0 THEN SUM(total_purchases)/SUM(total_loads)*100 ELSE 0 END)::numeric,1) || '%' AS \"Utilization %\"\nFROM reporting.vw_daily_purse_balance\nWHERE tenant_id='rfu-oregon'\nGROUP BY purse_name\nORDER BY purse_name",
          "refId": "A"
        }
      ]
    }
