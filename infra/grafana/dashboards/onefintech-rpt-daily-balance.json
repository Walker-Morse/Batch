    {
      "id": 10,
      "type": "table",
      "title": "Daily Balance Snapshot by Purse",
      "datasource": {
        "type": "grafana-postgresql-datasource",
        "uid": "cfglj9j8ghwqob"
      },
      "gridPos": {
        "x": 0,
        "y": 12,
        "w": 24,
        "h": 10
      },
      "options": {
        "cellHeight": "sm",
        "footer": {
          "show": false
        },
        "showHeader": true
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "filterable": true,
            "displayMode": "auto"
          }
        },
        "overrides": []
      },
      "pluginVersion": "10.4.3",
      "targets": [
        {
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "cfglj9j8ghwqob"
          },
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT\n    balance_date AS \"Date\",\n    purse_name AS \"Purse\",\n    purse_status AS \"Status\",\n    account_count AS \"Accounts\",\n    '$' || TO_CHAR(ROUND((total_opening_balance)::numeric,2),'FM999,999,990.00') AS \"Opening Balance\",\n    '$' || TO_CHAR(ROUND((total_loads)::numeric,2),'FM999,999,990.00') AS \"Loaded\",\n    '$' || TO_CHAR(ROUND((total_purchases)::numeric,2),'FM999,999,990.00') AS \"Purchases\",\n    '$' || TO_CHAR(ROUND((total_fees)::numeric,2),'FM999,999,990.00') AS \"Fees\",\n    '$' || TO_CHAR(ROUND((total_returns)::numeric,2),'FM999,999,990.00') AS \"Returns\",\n    '$' || TO_CHAR(ROUND((total_closing_balance)::numeric,2),'FM999,999,990.00') AS \"Closing Balance\"\nFROM reporting.vw_daily_purse_balance\nWHERE tenant_id='rfu-oregon'\nORDER BY balance_date DESC, purse_name",
          "refId": "A"
        }
      ]
    },
