      "targets": [
        {
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "cfglj9j8ghwqob"
          },
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT spend_category_code AS \"Code\",\n    CASE spend_category_code WHEN '5D' THEN 'Food & Beverages' WHEN '5A' THEN 'OTC / Health' ELSE spend_category_code END AS \"Category\",\n    COUNT(*) AS \"Items\", SUM(item_quantity) AS \"Units\",\n    '$' || TO_CHAR(ROUND((SUM(item_amount))::numeric,2),'FM999,999,990.00') AS \"Total\",\n    '$' || TO_CHAR(ROUND((AVG(item_amount))::numeric,2),'FM999,999,990.00') AS \"Avg Item\"\nFROM reporting.fact_spend_item_detail WHERE tenant_id='rfu-oregon'\nGROUP BY spend_category_code ORDER BY 5 DESC",
          "refId": "A"
        }
      ]
    },
