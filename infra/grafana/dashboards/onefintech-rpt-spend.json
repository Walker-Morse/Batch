          },
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT item_description AS \"Item\", upc AS \"UPC\", spend_category_code AS \"Cat\",\n    SUM(item_quantity) AS \"Units\",\n    '$' || TO_CHAR(ROUND((SUM(item_amount))::numeric,2),'FM999,999,990.00') AS \"Total\",\n    COUNT(*) AS \"Transactions\"\nFROM reporting.fact_spend_item_detail WHERE tenant_id='rfu-oregon'\nGROUP BY item_description,upc,spend_category_code ORDER BY 5 DESC LIMIT 20",
          "refId": "A"
        }
      ]
    },
