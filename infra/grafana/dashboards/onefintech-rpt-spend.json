      "targets": [
        {
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "cfglj9j8ghwqob"
          },
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT spend_category_code AS \"Category Code\",\n    CASE spend_category_code\n        WHEN '5D' THEN 'Food & Beverages'\n        WHEN '5A' THEN 'OTC / Health'\n        WHEN 'OF' THEN 'OTC (OF)'\n        WHEN 'OV' THEN 'OTC (OV)'\n        ELSE spend_category_code\n    END AS \"Category\",\n    COUNT(*) AS \"Items\",\n    SUM(item_quantity) AS \"Units\",\n    ROUND(SUM(item_amount)::numeric,2) AS \"Total ($)\",\n    ROUND(AVG(item_amount)::numeric,2) AS \"Avg Item ($)\"\nFROM reporting.fact_spend_item_detail WHERE tenant_id='rfu-oregon'\nGROUP BY spend_category_code ORDER BY 5 DESC",
          "refId": "A"
        }
      ],
      "title": "Spend by Category",
      "type": "table"
    },
