      "targets": [
        {
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "cfglj9j8ghwqob"
          },
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT item_description AS \"Item\",\n    upc AS \"UPC\",\n    spend_category_code AS \"Cat\",\n    SUM(item_quantity) AS \"Units\",\n    ROUND(SUM(item_amount)::numeric,2) AS \"Total ($)\",\n    COUNT(*) AS \"Transactions\"\nFROM reporting.fact_spend_item_detail WHERE tenant_id='rfu-oregon'\nGROUP BY item_description, upc, spend_category_code\nORDER BY 5 DESC LIMIT 20",
          "refId": "A"
        }
      ],
      "title": "Top Items by Sales",
      "type": "table"
    },
