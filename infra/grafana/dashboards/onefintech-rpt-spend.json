      "pluginVersion": "10.4.3",
      "targets": [
        {
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "cfglj9j8ghwqob"
          },
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT si.txn_datetime::date AS \"Date\",\n    si.merchant_name AS \"Merchant\",\n    '$' || TO_CHAR(ROUND((si.settle_amount)::numeric,2),'FM999,999,990.00') AS \"Total\",\n    sd.item_description AS \"Item\",\n    sd.spend_category_code AS \"Category\",\n    sd.item_quantity AS \"Qty\",\n    '$' || TO_CHAR(ROUND((sd.item_amount)::numeric,2),'FM999,999,990.00') AS \"Amount\",\n    sd.is_funded AS \"Funded\",\n    si.pan_masked AS \"PAN\"\nFROM reporting.fact_spend_item_detail sd\nJOIN reporting.fact_spend_item si ON si.spend_item_sk=sd.spend_item_sk\nWHERE sd.tenant_id='rfu-oregon'\nORDER BY si.txn_datetime DESC, sd.item_sequence LIMIT 500",
          "refId": "A"
        }
      ]
    }
