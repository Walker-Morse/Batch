        {
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "cfglj9j8ghwqob"
          },
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT purse_code AS \"Purse\",\n    COUNT(*) AS \"Members Loaded\",\n    '$' || TO_CHAR(ROUND((SUM(settle_amount))::numeric,2),'FM999,999,990.00') AS \"Total Loaded\",\n    '$' || TO_CHAR(ROUND((AVG(settle_amount))::numeric,2),'FM999,999,990.00') AS \"Avg Load\"\nFROM reporting.fact_monetary WHERE tenant_id='rfu-oregon' AND txn_type_code=1710\nGROUP BY purse_code ORDER BY purse_code",
          "refId": "A"
        }
      ]
    },
