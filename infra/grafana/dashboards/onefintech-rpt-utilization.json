      "targets": [
        {
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "cfglj9j8ghwqob"
          },
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT m.client_member_id AS \"Member ID\",\n    m.first_name AS \"First Name\", m.last_name AS \"Last Name\",\n    ab.purse_name AS \"Purse\",\n    '$' || TO_CHAR(ROUND((ab.total_valueload_amount)::numeric,2),'FM999,999,990.00') AS \"Loaded\",\n    '$' || TO_CHAR(ROUND((ab.total_purchase_amount)::numeric,2),'FM999,999,990.00') AS \"Spent\",\n    '$' || TO_CHAR(ROUND((ab.closing_balance)::numeric,2),'FM999,999,990.00') AS \"Balance\",\n    ROUND((100.0*ab.total_purchase_amount/NULLIF(ab.total_valueload_amount,0))::numeric,1) || '%' AS \"Util %\"\nFROM reporting.fact_account_balance ab\nLEFT JOIN reporting.dim_member m ON m.client_member_id=ab.pan_proxy_number AND m.tenant_id=ab.tenant_id\nWHERE ab.tenant_id='rfu-oregon'\nORDER BY ab.closing_balance DESC LIMIT 200",
          "refId": "A"
        }
      ]
    }
