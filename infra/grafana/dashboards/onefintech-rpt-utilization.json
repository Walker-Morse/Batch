      "targets": [
        {
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "cfglj9j8ghwqob"
          },
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT purse_name AS \"Purse\",\n    COUNT(*) AS \"Members\",\n    '$' || TO_CHAR(ROUND((SUM(total_valueload_amount))::numeric,2),'FM999,999,990.00') AS \"Total Loaded\",\n    '$' || TO_CHAR(ROUND((SUM(total_purchase_amount))::numeric,2),'FM999,999,990.00') AS \"Total Spent\",\n    '$' || TO_CHAR(ROUND((SUM(closing_balance))::numeric,2),'FM999,999,990.00') AS \"Total Balance\",\n    ROUND((100.0*SUM(total_purchase_amount)/NULLIF(SUM(total_valueload_amount),0))::numeric,1) || '%' AS \"Utilization\"\nFROM reporting.fact_account_balance WHERE tenant_id='rfu-oregon'\nGROUP BY purse_name ORDER BY purse_name",
          "refId": "A"
        }
      ]
    },
